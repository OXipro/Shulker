+            info[FIELD_LAST_SEEN]?.toLongOrNull()?.let(Instant::ofEpochMilli) ?: Instant.now(),
+            info[FIELD_FLEET_NAME]?.takeIf { it.isNotBlank() },
+            parseTags(info[FIELD_TAGS]),
